{
  "name": "@wyrd-company/a2a-ahp",
  "version": "0.1.0",
  "description": "Agent2Agent (A2A) server adapter backed by an Agent Host Protocol client.",
  "type": "module",
  "license": "MIT",
  "author": "Wyrd Company",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyrd-company/a2a-ahp.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "test": "node --test --import tsx test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@microsoft/agent-host-protocol": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.15.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@wyrd-company/ahp-server": "file:../ahp-server",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=20"
  }
}
